<!DOCTYPE html>
<html lang="<%= ui.htmlLang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title><%= ui.projectName %> · <%= ui.settingsTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'sans-serif'],
          },
          boxShadow: {
            soft: '0 0 0 1px rgba(15,23,42,0.06), 0 10px 30px rgba(15,23,42,0.08)',
          },
        },
      },
    };
  </script>
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
  <div class="mx-auto max-w-3xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="rounded-3xl border border-slate-200/70 bg-white p-5 shadow-soft sm:p-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <a href="/<%= lang === 'en' ? '?lang=en' : '' %>" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 transition hover:text-slate-900"><%= ui.backToDashboard %></a>
          <div class="mt-4 flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-900 text-lg text-white">⚙️</div>
            <div>
              <p class="text-sm font-medium uppercase tracking-[0.24em] text-slate-400"><%= ui.projectName %></p>
              <h1 class="text-3xl font-semibold tracking-tight text-slate-950"><%= ui.settingsTitle %></h1>
            </div>
          </div>
          <p class="mt-4 max-w-2xl text-sm leading-6 text-slate-600"><%= ui.settingsDescription %></p>
        </div>
        <a href="<%= languageSwitchHref %>" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-white">🌍 <%= ui.switchLanguage %></a>
      </div>
    </div>

    <div class="mt-6 rounded-3xl border border-slate-200/70 bg-slate-950 p-5 text-white shadow-soft sm:p-6">
      <div class="mb-5">
        <p class="text-sm font-medium text-slate-400"><%= ui.changePassword %></p>
        <h2 class="mt-1 text-2xl font-semibold tracking-tight"><%= ui.currentPassword %> → <%= ui.newPassword %></h2>
        <p class="mt-2 text-sm leading-6 text-slate-300"><%= ui.passwordCardDescription %></p>
      </div>

      <% if (error) { %>
        <div class="mb-4 rounded-2xl border border-amber-400/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="mb-4 rounded-2xl border border-emerald-400/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100"><%= success %></div>
      <% } %>

      <form method="POST" action="/settings/password<%= lang === 'en' ? '?lang=en' : '' %>" class="grid gap-4">
        <div>
          <label class="mb-2 block text-sm font-medium text-slate-200"><%= ui.currentPassword %></label>
          <input name="current" type="password" required class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200"><%= ui.newPassword %></label>
            <input name="new_pass" type="password" required class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-200"><%= ui.confirmPassword %></label>
            <input name="confirm" type="password" required class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
          </div>
        </div>
        <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-white px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100"><%= ui.save %></button>
      </form>

      <p class="mt-4 rounded-2xl border border-slate-800 bg-slate-900/60 px-4 py-3 text-sm leading-6 text-slate-300"><%= ui.defaultCredentialTip %></p>
    </div>
  </div>
</body>
</html>

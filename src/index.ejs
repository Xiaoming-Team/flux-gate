<!DOCTYPE html>
<html lang="<%= ui.htmlLang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title><%= ui.projectName %> · <%= ui.proxyManager %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui', '-apple-system', 'BlinkMacSystemFont', 'sans-serif'],
          },
          boxShadow: {
            soft: '0 0 0 1px rgba(15,23,42,0.06), 0 10px 30px rgba(15,23,42,0.08)',
            card: '0 0 0 1px rgba(15,23,42,0.06), 0 4px 16px rgba(15,23,42,0.06)',
          },
        },
      },
    };
  </script>
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <header class="mb-6 flex flex-col gap-4 rounded-3xl border border-slate-200/70 bg-white/90 p-4 shadow-soft backdrop-blur sm:p-6 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-600">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          <%= ui.heroBadge %>
        </div>
        <div class="mt-4 flex items-center gap-3">
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-900 text-lg text-white shadow-lg shadow-slate-900/10">⚡</div>
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.24em] text-slate-400"><%= ui.dashboardTitle %></p>
            <h1 class="text-2xl font-semibold tracking-tight text-slate-950 sm:text-3xl"><%= ui.projectName %></h1>
          </div>
        </div>
        <p class="mt-4 text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl"><%= ui.heroSubtitle %></p>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600 sm:text-base"><%= ui.heroDescription %></p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end">
        <a href="<%= languageSwitchHref %>" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-50">🌍 <%= ui.switchLanguage %></a>
        <a href="/settings<%= lang === 'en' ? '?lang=en' : '' %>" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-lg shadow-slate-900/10 transition hover:bg-slate-800">⚙️ <%= ui.settings %></a>
      </div>
    </header>

    <main class="grid gap-6 xl:grid-cols-[1.35fr_0.95fr]">
      <section class="rounded-3xl border border-slate-200/70 bg-white p-5 shadow-soft sm:p-6">
        <div class="mb-5">
          <div class="flex flex-wrap items-center gap-3">
            <h2 class="text-2xl font-semibold tracking-tight text-slate-950"><%= ui.allRoutes %></h2>
            <div class="flex flex-wrap gap-2 text-xs font-medium">
              <span id="route-count-badge" class="rounded-full bg-slate-100 px-3 py-1 text-slate-600"></span>
              <span id="enabled-count-badge" class="rounded-full bg-emerald-100 px-3 py-1 text-emerald-700"></span>
            </div>
          </div>
          <p class="mt-3 text-sm leading-6 text-slate-500"><%= ui.routeListDescription %></p>
        </div>
        <div id="route-list"></div>
      </section>

      <section class="rounded-3xl border border-slate-200/70 bg-slate-950 p-5 text-slate-50 shadow-soft sm:p-6">
        <div class="mb-5">
          <h2 id="route-form-title" class="text-2xl font-semibold tracking-tight"><%= ui.addOrUpdateRoute %></h2>
          <p id="route-form-subtitle" class="mt-2 text-sm leading-6 text-slate-300"><%= ui.addPanelDescription %></p>
        </div>

        <form class="grid gap-4" onsubmit="saveRoute(event)">
          <input type="hidden" id="f-original-subdomain">

          <div>
            <label for="f-sub" class="mb-2 block text-sm font-medium text-slate-200"><%= ui.subdomain %></label>
            <div class="flex overflow-hidden rounded-2xl border border-slate-700 bg-slate-900/70 transition focus-within:border-sky-400 focus-within:ring-4 focus-within:ring-sky-400/15">
              <input name="subdomain" id="f-sub" placeholder="nas" required class="min-w-0 flex-1 border-0 bg-transparent px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none focus:ring-0">
              <span class="inline-flex items-center border-l border-slate-700 bg-slate-900 px-4 text-sm font-medium text-slate-400">.<%= baseDomain %></span>
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="f-ip" class="mb-2 block text-sm font-medium text-slate-200"><%= ui.targetIp %></label>
              <input name="ip" id="f-ip" placeholder="192.168.1.100" required class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
            </div>
            <div>
              <label for="f-port" class="mb-2 block text-sm font-medium text-slate-200"><%= ui.port %></label>
              <input name="port" id="f-port" placeholder="8080" required class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
            </div>
          </div>
          <div>
            <label for="f-desc" class="mb-2 block text-sm font-medium text-slate-200"><%= ui.descriptionOptional %></label>
            <input name="description" id="f-desc" placeholder="<%= ui.descriptionPlaceholder %>" class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
          </div>
          <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 text-sm text-slate-200">
            <p class="mb-3 font-medium text-slate-100"><%= ui.authSectionTitle %></p>
            <div class="grid gap-3">
              <label class="flex items-start gap-3">
                <input type="radio" id="auth-mode-default" name="auth_mode" value="default" checked class="h-4 w-4 border-slate-600 bg-slate-800 text-sky-500 focus:ring-sky-400/20">
                <span><%= ui.authDefaultFormLabel %></span>
              </label>
              <label class="flex items-start gap-3">
                <input type="radio" id="auth-mode-custom" name="auth_mode" value="custom" class="h-4 w-4 border-slate-600 bg-slate-800 text-sky-500 focus:ring-sky-400/20">
                <span><%= ui.authCustomLabel %></span>
              </label>
              <label class="flex items-start gap-3">
                <input type="radio" id="auth-mode-none" name="auth_mode" value="none" class="h-4 w-4 border-slate-600 bg-slate-800 text-sky-500 focus:ring-sky-400/20">
                <span><%= ui.authNoneLabel %></span>
              </label>
            </div>
            <div id="custom-auth-fields" class="hidden mt-4 grid gap-4 sm:grid-cols-2">
              <div>
                <label for="f-username" class="mb-2 block text-sm font-medium text-slate-200"><%= ui.customUsername %></label>
                <input name="username" id="f-username" placeholder="alice" class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
              </div>
              <div>
                <label for="f-password" class="mb-2 block text-sm font-medium text-slate-200"><%= ui.customPassword %></label>
                <input name="password" id="f-password" type="password" placeholder="••••••••" class="w-full rounded-2xl border border-slate-700 bg-slate-900/70 px-4 py-3 text-base text-white placeholder:text-slate-500 outline-none transition focus:border-sky-400 focus:ring-4 focus:ring-sky-400/15">
              </div>
            </div>
            <p id="no-password-warning" class="hidden mt-4 rounded-2xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm leading-6 text-red-300"><%= ui.noPasswordWarning %></p>
          </div>
          <label class="flex items-start gap-3 rounded-2xl border border-slate-800 bg-slate-900/60 px-4 py-3 text-sm text-slate-200">
            <input type="checkbox" id="f-enabled" name="enabled" checked class="h-4 w-4 rounded border-slate-600 bg-slate-800 text-sky-500 focus:ring-sky-400/20">
            <span><%= ui.startRouteLabel %></span>
          </label>
          <div class="flex flex-col gap-3 sm:flex-row">
            <button id="route-submit-button" type="submit" class="inline-flex items-center justify-center rounded-2xl bg-white px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100"><%= ui.add %></button>
            <button id="route-cancel-button" type="button" onclick="resetRouteForm()" class="hidden inline-flex items-center justify-center rounded-2xl border border-slate-700 px-4 py-3 text-sm font-semibold text-slate-200 transition hover:bg-slate-900"><%= ui.cancelEdit %></button>
          </div>
        </form>

        <div id="form-msg" class="mt-4"></div>
      </section>
    </main>
  </div>

<script>
const baseDomain = <%- JSON.stringify(baseDomain) %>;
const ui = <%- JSON.stringify(ui) %>;
const routes = <%- JSON.stringify(routes) %>;

function updateRouteCount() {
  const routeCountBadge = document.getElementById('route-count-badge');
  const enabledCountBadge = document.getElementById('enabled-count-badge');
  const enabledCount = routes.filter((route) => !route.disabled).length;

  if (routeCountBadge) routeCountBadge.textContent = ui.allRoutesCount.replace('{count}', String(routes.length));
  if (enabledCountBadge) enabledCountBadge.textContent = ui.enabledRoutesCount.replace('{count}', String(enabledCount));
}

function renderAuthBadgeLabel(route) {
  if (route.no_password) return ui.authNoneLabel;
  if (route.has_custom_auth) {
    if (route.username) {
      return ui.authCustomWithUsernameLabel.replace('{username}', route.username);
    }
    return ui.authCustomLabel;
  }
  return ui.authDefaultLabel;
}

function getRouteStatusLabel(route) {
  return route.disabled ? ui.routeDisabledState : ui.routeEnabledState;
}

function getRouteStatusClass(route) {
  return route.disabled
    ? 'border-slate-300 bg-slate-100 text-slate-600'
    : 'border-emerald-200 bg-emerald-50 text-emerald-700';
}

function getRouteAuthClass(route) {
  if (route.no_password) return 'border-red-200 bg-red-50 text-red-700';
  if (route.has_custom_auth) return 'border-sky-200 bg-sky-50 text-sky-700';
  return 'border-slate-200 bg-slate-50 text-slate-600';
}

function updateNoPasswordWarning() {
  const warning = document.getElementById('no-password-warning');
  if (!warning) return;
  warning.classList.toggle('hidden', document.querySelector('input[name="auth_mode"]:checked')?.value !== 'none');
}

function toggleAuthModeFields() {
  const mode = document.querySelector('input[name="auth_mode"]:checked')?.value || 'default';
  const customFields = document.getElementById('custom-auth-fields');
  if (customFields) customFields.classList.toggle('hidden', mode !== 'custom');
  updateNoPasswordWarning();
}

function icon(name) {
  const cls = 'h-4 w-4';
  const icons = {
    edit: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="${cls}" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 3.487a2.25 2.25 0 1 1 3.182 3.182L8.25 18.463 4.5 19.5l1.037-3.75L16.862 3.487Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 5.25 18.75 9" /></svg>`,
    play: `<svg viewBox="0 0 24 24" fill="currentColor" class="${cls}" aria-hidden="true"><path d="M8.25 6.75v10.5a.75.75 0 0 0 1.154.636l8.25-5.25a.75.75 0 0 0 0-1.272l-8.25-5.25A.75.75 0 0 0 8.25 6.75Z" /></svg>`,
    pause: `<svg viewBox="0 0 24 24" fill="currentColor" class="${cls}" aria-hidden="true"><path d="M6.75 5.25A.75.75 0 0 1 7.5 4.5h2.25a.75.75 0 0 1 .75.75v13.5a.75.75 0 0 1-.75.75H7.5a.75.75 0 0 1-.75-.75V5.25Zm6.75 0a.75.75 0 0 1 .75-.75h2.25a.75.75 0 0 1 .75.75v13.5a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1-.75-.75V5.25Z" /></svg>`,
    trash: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="${cls}" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7.5h12" /><path stroke-linecap="round" stroke-linejoin="round" d="m9.75 7.5.375-1.5A1.125 1.125 0 0 1 11.214 5.25h1.572c.516 0 .966.35 1.089.85l.375 1.4" /><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 7.5v9.75A2.25 2.25 0 0 0 10.5 19.5h3A2.25 2.25 0 0 0 15.75 17.25V7.5" /></svg>`,
  };
  return icons[name] || '';
}

function renderRoutes() {
  const el = document.getElementById('route-list');
  updateRouteCount();

  if (routes.length === 0) {
    el.innerHTML = `
      <div class="rounded-3xl border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-2xl shadow-card">🚀</div>
        <p class="mt-4 text-base font-medium text-slate-900">${ui.emptyRoutes}</p>
        <p class="mt-2 text-sm text-slate-500">${ui.addPanelDescription}</p>
      </div>`;
    return;
  }

  el.innerHTML = `<div class="grid gap-3 md:grid-cols-2">${routes.map((r) => {
    const routeName = `${r.subdomain}.${baseDomain}`;
    const title = r.disabled
      ? `<h3 class="break-all text-base font-semibold tracking-tight text-slate-400">${routeName}</h3>`
      : `<a href="https://${routeName}" target="_blank" rel="noreferrer" class="mt-1 block group rounded-2xl outline-none transition focus-visible:ring-2 focus-visible:ring-sky-400/40"><h3 class="break-all text-base font-semibold tracking-tight text-slate-950 transition group-hover:text-sky-600">${routeName}</h3></a>`;

    return `
      <article class="rounded-3xl border ${r.disabled ? 'border-slate-200 bg-slate-100/80' : 'border-slate-200 bg-slate-50'} p-4 shadow-card transition hover:-translate-y-0.5 hover:bg-white">
        <div class="flex items-start gap-3">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2">
              <p class="text-[11px] font-medium uppercase tracking-[0.22em] text-slate-400">${ui.subdomain}</p>
              <span class="rounded-full border px-2.5 py-1 text-[11px] font-medium ${getRouteStatusClass(r)}">${getRouteStatusLabel(r)}</span>
            </div>
            <div class="mt-1">${title}</div>
            <div class="mt-2 rounded-2xl bg-white px-3 py-2 font-mono text-sm text-slate-700 shadow-sm">${r.ip}:${r.port}</div>
            <div class="mt-2 flex flex-wrap gap-2 text-xs font-medium">
              <span class="rounded-full border px-2.5 py-1 ${getRouteAuthClass(r)}">${renderAuthBadgeLabel(r)}</span>
            </div>
            <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-500">${r.description || ui.noDescription}</p>
          </div>
          <div class="flex flex-col items-end gap-2">
            <button type="button" aria-label="${ui.editLabel} ${routeName}" class="inline-flex h-9 w-9 items-center justify-center rounded-2xl border border-slate-200 bg-white text-sm text-slate-500 transition hover:border-sky-200 hover:bg-sky-50 hover:text-sky-600" onclick="editRoute('${r.subdomain}')">${icon('edit')}</button>
            <button type="button" aria-label="${r.disabled ? ui.enableLabel : ui.disableLabel} ${routeName}" class="inline-flex h-9 w-9 items-center justify-center rounded-2xl border border-slate-200 bg-white text-sm text-slate-500 transition hover:border-amber-200 hover:bg-amber-50 hover:text-amber-600" onclick="toggleRouteDisabled('${r.subdomain}')">${icon(r.disabled ? 'play' : 'pause')}</button>
            <button type="button" aria-label="${ui.deleteLabel} ${routeName}" class="inline-flex h-9 w-9 items-center justify-center rounded-2xl border border-slate-200 bg-white text-sm text-slate-500 transition hover:border-rose-200 hover:bg-rose-50 hover:text-rose-600" onclick="deleteRoute('${r.subdomain}')">${icon('trash')}</button>
          </div>
        </div>
      </article>`;
  }).join('')}</div>`;
}

function resetRouteForm() {
  document.getElementById('f-original-subdomain').value = '';
  document.getElementById('f-sub').value = '';
  document.getElementById('f-ip').value = '';
  document.getElementById('f-port').value = '';
  document.getElementById('f-desc').value = '';
  document.getElementById('f-username').value = '';
  document.getElementById('f-password').value = '';
  document.getElementById('auth-mode-default').checked = true;
  document.getElementById('f-enabled').checked = true;
  toggleAuthModeFields();
  document.getElementById('route-form-title').textContent = ui.addOrUpdateRoute;
  document.getElementById('route-form-subtitle').textContent = ui.addPanelDescription;
  document.getElementById('route-submit-button').textContent = ui.add;
  document.getElementById('route-cancel-button').classList.add('hidden');
}

function editRoute(subdomain) {
  const route = routes.find((item) => item.subdomain === subdomain);
  if (!route) return;

  document.getElementById('f-original-subdomain').value = route.subdomain;
  document.getElementById('f-sub').value = route.subdomain;
  document.getElementById('f-ip').value = route.ip;
  document.getElementById('f-port').value = route.port;
  document.getElementById('f-desc').value = route.description || '';
  document.getElementById('f-username').value = route.username || '';
  document.getElementById('f-password').value = '';
  if (route.no_password) document.getElementById('auth-mode-none').checked = true;
  else if (route.has_custom_auth) document.getElementById('auth-mode-custom').checked = true;
  else document.getElementById('auth-mode-default').checked = true;
  document.getElementById('f-enabled').checked = !Boolean(route.disabled);
  toggleAuthModeFields();
  document.getElementById('route-form-title').textContent = ui.addOrUpdateRoute;
  document.getElementById('route-form-subtitle').textContent = ui.editingRoute.replace('{route}', `${route.subdomain}.${baseDomain}`);
  document.getElementById('route-submit-button').textContent = ui.update;
  document.getElementById('route-cancel-button').classList.remove('hidden');
  document.getElementById('f-sub').focus();
}

async function saveRoute(e) {
  e.preventDefault();
  const originalSubdomain = document.getElementById('f-original-subdomain').value.trim();
  const subdomain = document.getElementById('f-sub').value.trim();
  const ip = document.getElementById('f-ip').value.trim();
  const port = document.getElementById('f-port').value.trim();
  const description = document.getElementById('f-desc').value.trim();
  const username = document.getElementById('f-username').value.trim();
  const password = document.getElementById('f-password').value;
  const authMode = document.querySelector('input[name="auth_mode"]:checked')?.value || 'default';
  const no_password = authMode === 'none';
  const effectiveUsername = authMode === 'custom' ? username : '';
  const effectivePassword = authMode === 'custom' ? password : '';
  const disabled = !document.getElementById('f-enabled').checked;
  const msg = document.getElementById('form-msg');

  const res = await fetch('/api/routes', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      original_subdomain: originalSubdomain,
      subdomain,
      ip,
      port,
      description,
      username: effectiveUsername,
      password: effectivePassword,
      no_password,
      disabled,
    }),
  });

  if (res.status === 401) {
    alert(ui.relogin);
    return;
  }

  const data = await res.json();
  if (data.error) {
    msg.innerHTML = `<div class="rounded-2xl border border-amber-400/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">${data.error}</div>`;
    return;
  }

  routes.splice(0, routes.length, ...(data.routes || []));
  msg.innerHTML = `<div class="rounded-2xl border border-emerald-400/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">${originalSubdomain ? ui.routeSavedUpdated : ui.routeSavedAdded}</div>`;
  renderRoutes();
  resetRouteForm();
}

async function toggleRouteDisabled(subdomain) {
  const route = routes.find((item) => item.subdomain === subdomain);
  if (!route) return;

  const res = await fetch(`/api/routes/${subdomain}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ disabled: !route.disabled }),
  });

  if (res.status === 401) {
    alert(ui.relogin);
    return;
  }

  const data = await res.json();
  if (data.error) return;
  routes.splice(0, routes.length, ...(data.routes || []));
  renderRoutes();
}

async function deleteRoute(subdomain) {
  const routeName = `${subdomain}.${baseDomain}`;
  if (!confirm(ui.deleteConfirm.replace('{route}', routeName))) return;
  await fetch(`/api/routes/${subdomain}`, { method: 'DELETE' });
  const idx = routes.findIndex((r) => r.subdomain === subdomain);
  if (idx >= 0) routes.splice(idx, 1);
  renderRoutes();
  if (document.getElementById('f-original-subdomain').value === subdomain) {
    resetRouteForm();
  }
}

renderRoutes();
document.querySelectorAll('input[name="auth_mode"]').forEach((input) => {
  input.addEventListener('change', toggleAuthModeFields);
});
toggleAuthModeFields();
</script>
</body>
</html>
